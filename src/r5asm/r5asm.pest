/// Risc V assemble language
asm_prog = { SOI ~ section* ~ EOI }

section = { section_tag ~ (label | instruction | directive)* }

section_tag = { ".text" | ".data" | ".bss" | ".rodata"} 
label = ${ symbol ~ ":" }

directive = { 
    align_directive |
    file_directive |
    globl_local_directive |
    common_directive |
    ident_directive |
    size_directive |
    string_directive |
    equ_directive |
    option_directive |
    byte_directive |
    sleb128_directive |
    uleb128_directive |
    p2align_directive |
    balign_directive |
    zero_directive |
    variant_cc_directive | 
    attribute_directive |
    customer_attribute_directive |
    type_directive
}

type_directive = _{ #inc_name = type_directive_name ~ identifier ~ "," ~ ( function_type | object_type ) }
type_directive_name = { ".type" }
function_type = { "@function" }
object_type = { "@object" }

align_directive = _{ #inc_name = align_directive_name ~ integer }
align_directive_name = { ".align" }

file_directive = _{ #inc_name = file_directive_name ~ string }
file_directive_name = { ".file" }

globl_local_directive = _{ #inc_name = globl_local_directive_name ~ identifier }
globl_local_directive_name = { ".globl" | ".local" | ".extern" }

common_directive = _{ #inc_name = common_directive_name ~ identifier ~ "," ~ integer ~ "," ~ integer }
common_directive_name = { "common" | "comm" }

ident_directive = _{ #inc_name = ident_directive_name ~ string }
ident_directive_name = { ".ident" }

size_directive = _{ #inc_name = size_directive_name ~ identifier ~ "," ~ expression }
size_directive_name = { ".size" }

string_directive = _{ #inc_name = string_directive_name ~ string }
string_directive_name = { ".string" | ".asciz" }

equ_directive = _{ #inc_name = equ_directive_name ~ identifier ~ "," ~ (integer | string | identifier) }
equ_directive_name = { ".equ" }

option_directive = _{ #inc_name = option_directive_name ~ option_directive_param }
option_directive_name = { ".option" }
option_directive_param = { "arch" | "rvc" | "norvc" | "pic" | "nopic" | "relax" | "norelax" | "push" | "pop" }

byte_directive = _{ #inc_name = byte_directive_name ~ expression ~ ("," ~ expression)* }
byte_directive_name = { ".byte" | ".2byte" | ".4byte" | ".8byte" | ".short" | ".long" | ".quad" | ".half" | ".float" | ".double" | ".dword" | ".word" | ".dtprelword" | ".dtpreldworld" }

sleb128_directive = _{ #inc_name = sleb128_directive_name ~ expression }
sleb128_directive_name = { ".sleb128" }

uleb128_directive = _{ #inc_name = uleb128_directive_name ~ expression }
uleb128_directive_name = { ".uleb128" }

p2align_directive = _{ #inc_name = p2align_directive_name ~ integer ~ ("pad_value" ~ "=" ~ "0")? ~ integer }
p2align_directive_name = { ".p2align" }

balign_directive = _{ #inc_name = balign_directive_name ~ integer ~ ("pad_value" ~ "=" ~ "0")? }
balign_directive_name = { ".balign" }

zero_directive = _{ #inc_name = zero_directive_name ~ integer }
zero_directive_name = { ".zero" | ".space" }

variant_cc_directive = _{ #inc_name = variant_cc_directive_name ~ identifier } 
variant_cc_directive_name = { ".variant_cc" }

attribute_directive = _{ #inc_name = attribute_directive_name ~ (identifier | integer) ~ (identifier | integer) }
attribute_directive_name = { ".attribute" }

customer_attribute_directive = { #inc_name = end_directive }
end_directive = { ".end" }

// ⁂ R5 supported instructions
instruction = { basic_instructions | pseudoinstructions }
basic_instructions = { 
    rv_zbb_instructions |       //Zbb extension
    rv_zbs_instructions |       //Zbs extension
    rv_zba_instructions |       //Zba extension
    base_integer_instructions | //basic 32 integer
    rvc_instructions |          //compressed 16-bit extension
    rv_64_128 |                 //64 and 128 integer
    rv_privileged_instructions |    //privileged instructions
    rvm64_128_instructions | rvm32_instructions |   //multiple-divide extension
    rv32a_instructions |            //atomic extension
    rv64a_128a_instructions |       //atomic extension
    rvf_instructions        |       //floating points extension
    rvf64_128_instructions
}

base_integer_instructions = { 
    #inc_name = base_integer_instructions_load_incs ~ rd ~ "," ~ (imm | relocation_function) ~ "(" ~ rs1 ~ ")" |
    #inc_name = base_integer_instructions_load_incs ~ rd ~ "," ~ rs1 ~ "," ~ (imm | relocation_function) |                  //loads
    #inc_name = base_integer_instructions_store_incs ~ rs1 ~ "," ~ (imm | relocation_function) ~ "(" ~ rs2 ~ ")" |
    #inc_name = base_integer_instructions_store_incs ~ rs1 ~ "," ~ rs2 ~ "," ~ imm |                                       //stores
    #inc_name = base_integer_instructions_shift_incs ~ rd ~ "," ~ rs1 ~ "," ~ rs2 |                  //shifts
    #inc_name = base_integer_instructions_shift_imm_incs ~ rd ~ "," ~ rs1 ~ "," ~  shamt |          //shift with imm
    #inc_name = base_integer_instructions_addi ~ rd ~ "," ~ rs1 ~ "," ~ (imm | relocation_function) | 
    #inc_name = (base_integer_instructions_addi | base_integer_instructions_add_sub ) ~ rd ~ "," ~ rs1 ~ "," ~ rs2 | 
    #inc_name = base_integer_instructions_arithemtic ~ rd ~ "," ~ (imm | relocation_function ) |                                     //arithemtic
    #inc_name = base_integer_instructions_logic_imm_incs ~ rd ~ "," ~ rs1 ~ "," ~ imm |
    #inc_name = base_integer_instructions_logic_incs ~ rd ~ "," ~ rs1 ~ "," ~ rs2 |                //logical
    #inc_name = base_integer_instructions_compare_imm_incs ~ rd ~ "," ~ rs1 ~ "," ~ imm |
    #inc_name = base_integer_instructions_compare_incs ~ rd ~ "," ~ rs1 ~ "," ~ rs3 |                       //compare
    #inc_name = base_integer_instructions_branch_incs ~ rd ~ "," ~ rs1 ~ "," ~ imm |   //branches
    #inc_name = base_integer_instructions_jalr ~  rd ~ "," ~ ((rs1 ~ "," ~ imm) | (imm ~ "(" ~ rs1 ~ ")") | rs1 )  | 
    #inc_name = base_integer_instructions_jal ~ rd ~ "," ~ rs1 ~ "," ~ imm |               //jump
    #inc_name = base_integer_instructions_syc_incs |                             //synch
    #inc_name = base_integer_instructions_system_call_incs |                              //system call
    #inc_name = base_integer_instructions_counters_incs ~ rd  //counters   
}

base_integer_instructions_load_incs = { ^"lbu" | ^"lb" | ^"lhu" | ^"lh" | ^"lw" }
base_integer_instructions_store_incs = { ^"sb" | ^"sh" | ^"sw" }
base_integer_instructions_shift_incs = { ^"sll" | ^"srl" | ^"sra" }
base_integer_instructions_shift_imm_incs = { ^"slli" | ^"srli" | ^"srai" }
base_integer_instructions_addi = {  ^"addi" }
base_integer_instructions_add_sub = { ^"add" | ^"sub" }
base_integer_instructions_arithemtic = { (^"lui" | ^"auipc") }
base_integer_instructions_logic_imm_incs = { (^"xori" | ^"ori" | ^"andi") }
base_integer_instructions_logic_incs = { (^"xor" | ^"or" | ^"and") }
base_integer_instructions_compare_imm_incs = { (^"sltiu" | ^"slti") }
base_integer_instructions_compare_incs = { (^"sltu" | ^"slt") }
base_integer_instructions_branch_incs = { (^"beq" | ^"bne" | ^"bltu" | ^"blt" | ^"bgeu" | ^"bge" ) }
base_integer_instructions_jalr = { ^"jalr" }
base_integer_instructions_jal = { ^"jal" }
base_integer_instructions_syc_incs = { ^"fence.i" | ^"fence"  }
base_integer_instructions_system_call_incs = { ^"scall" | ^"sbreak" }
base_integer_instructions_counters_incs = { (^"rdcycleh" | ^"rdcycle" | ^"rdtimeh" | ^"rdtime" | ^"rdinstreth" | ^"rdinstret") }

rvc_instructions = {
    #inc_name = rvc_instructions_load_imm_incs ~ rd ~ "," ~ imm |
    #inc_name = rvc_instructions_load_incs ~ rd ~ "," ~ rs1 ~ "," ~ imm |            //loads
    #inc_name = rvc_instructions_store_imm_incs ~ rs2 ~ "," ~ imm | 
    #inc_name = rvc_instructions_store_incs ~ rs1 ~ "," ~ rs2 ~ "," ~ imm |           //stores
    #inc_name = rvc_instructions_arithematic_incs ~ rd ~ "," ~ rs1 | 
    #inc_name = rvc_instructions_arithematic_imm_incs ~ rd ~ "," ~ imm |
    #inc_name = rvc_instructions_addi ~ ^"x0" ~ "," ~ imm |                  //arithemtic
    #inc_name = rvc_instructions_ssli ~ rd ~ "," ~ imm |                        //shifts
    #inc_name = rvc_instructions_branch_incs ~ rs1 ~ "," ~ imm |         //branches
    #inc_name = rvc_instructions_jump_link_incs ~ rs1 |
    #inc_name = rvc_instructions_jump_link_incs ~ imm |
    #inc_name = rvc_instructions_jump_link_incs ~ rd ~ "," ~ rs1 |                          //jump and link
    #inc_name = rvc_instructions_break                                          //system     
}

rvc_instructions_load_imm_incs = { (^"c.lwsp" | ^"c.ldsp" | ^"c.lqsp") }
rvc_instructions_load_incs = { (^"c.lw" | ^"c.ld" | ^"c.lq") }
rvc_instructions_store_imm_incs = { (^"c.swsp" | ^"c.sdsp" | ^"c.sqsp") }
rvc_instructions_store_incs = { (^"c.sw" | ^"c.sd" | ^"c.sq") }
rvc_instructions_arithematic_imm_incs = { (^"c.addiw" | ^"c.addi" | ^"c.lui" | ^"c.lu" | ^"c.addi4spn") }
rvc_instructions_arithematic_incs = { (^"c.addw" | ^"c.add" | ^"c.mv" | ^"c.sub") }
rvc_instructions_addi = { ^"c.addi16sp" }
rvc_instructions_ssli = { ^"c.slli" }
rvc_instructions_branch_incs = { (^"c.beqz" | ^"c.bnez") }
rvc_instructions_jump_link_incs = { ^"c.jalr" | (^"c.jal" | ^"c.j") |  ^"c.jr" }
rvc_instructions_break = { ^"c.break" }

